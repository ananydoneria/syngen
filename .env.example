# Copy to .env and fill values as needed.

# LLM parser provider: gemini | openai
PROMPT_PARSER_LLM_PROVIDER=gemini

# Gemini (recommended low-cost parser rewrite)
GEMINI_API_KEY=
PROMPT_PARSER_GEMINI_MODEL=gemini-2.5-flash

# OpenAI (optional)
OPENAI_API_KEY=
PROMPT_PARSER_LLM_MODEL=gpt-4.1-mini

# Set to 1 for local mock parser behavior (no API calls)
PROMPT_PARSER_LLM_MOCK=0

